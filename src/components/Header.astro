---
/** Cabecera principal del sitio */
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/blog', label: 'Blog' },
  { href: '/sobre-nosotros', label: 'Sobre nosotros' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white/80 backdrop-blur-sm border-b border-texto/10 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="Navegación principal">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <span class="font-display text-2xl font-bold text-texto group-hover:text-verde transition-colors">
        Renta<span class="text-verde">Base</span>
      </span>
    </a>

    <!-- Navegación desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-verde',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-verde'
                : 'text-texto/70',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Botón menú móvil -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-texto/70 hover:text-verde transition-colors"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Menú móvil -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-texto/10 bg-white">
    <ul class="px-4 py-4 space-y-3">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block text-sm font-medium py-1 transition-colors hover:text-verde',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-verde'
                : 'text-texto/70',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
