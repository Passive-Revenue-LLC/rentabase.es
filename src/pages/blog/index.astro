---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  seo={{
    title: 'Blog',
    description: 'Artículos sobre inversión, ahorro, criptomonedas y fiscalidad en España. Aprende a gestionar tu dinero de forma inteligente.',
    url: '/blog',
  }}
>
  <section class="max-w-6xl mx-auto px-4 py-12 md:py-16">
    <header class="mb-12 animate-fade-up">
      <h1 class="font-display text-4xl md:text-5xl font-bold mb-4">Blog</h1>
      <p class="text-lg text-texto/60 max-w-2xl">
        Todos nuestros artículos sobre inversión, ahorro, criptomonedas y fiscalidad.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 reveal-stagger">
      {allPosts.map((post) => (
        <div class="reveal">
          <ArticleCard post={post} />
        </div>
      ))}
    </div>

    {allPosts.length === 0 && (
      <p class="text-center text-texto/50 py-20">No hay artículos publicados todavía.</p>
    )}
  </section>
</BaseLayout>
